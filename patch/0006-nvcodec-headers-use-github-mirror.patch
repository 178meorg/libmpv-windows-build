From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex-ice@gmail.com>
Date: Wed, 8 Jul 2026 20:00:00 +0800
Subject: [PATCH] nvcodec-headers: use FFmpeg git

---
 packages/nvcodec-headers.cmake | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/packages/nvcodec-headers.cmake b/packages/nvcodec-headers.cmake
index 0000000..0000000 100644
--- a/packages/nvcodec-headers.cmake
+++ b/packages/nvcodec-headers.cmake
@@ -1,7 +1,7 @@
 ExternalProject_Add(nvcodec-headers
     DOWNLOAD_DIR ${SOURCE_LOCATION}
     UPDATE_COMMAND ""
-    GIT_REPOSITORY https://git.videolan.org/git/ffmpeg/nv-codec-headers.git
+    GIT_REPOSITORY https://code.ffmpeg.org/FFmpeg/nv-codec-headers.git
     SOURCE_DIR ${SOURCE_LOCATION}
     GIT_CLONE_FLAGS "--filter=tree:0"
     CONFIGURE_COMMAND ""
