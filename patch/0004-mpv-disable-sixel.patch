From 3f9e0fd0c3e3a2b4b2e743f4d53d3c0d7d5c9a11 Mon Sep 17 00:00:00 2001
From: codex <codex-ice@gmail.com>
Date: Wed, 13 May 2026 23:55:00 +0800
Subject: [PATCH] mpv: disable sixel support

libsixel is currently failing to build in CI, which blocks the default
64-bit mpv package even though sixel is an optional output path. Stop
depending on libsixel and configure mpv without sixel support until the
upstream package recipe is fixed.
---
 packages/mpv-release.cmake | 4 ++--
 packages/mpv.cmake         | 6 +++---
 2 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/packages/mpv-release.cmake b/packages/mpv-release.cmake
index 8f38f5a..cfb7bfe 100644
--- a/packages/mpv-release.cmake
+++ b/packages/mpv-release.cmake
@@ -38,7 +38,7 @@ ExternalProject_Add(mpv-release
         vapoursynth
         libsdl2
         subrandr
-        libsixel
+        # libsixel
     URL ${LINK}
     SOURCE_DIR ${SOURCE_LOCATION}
     CONFIGURE_COMMAND ${EXEC} CONF=1 meson setup <BINARY_DIR> <SOURCE_DIR>
@@ -68,7 +68,7 @@ ExternalProject_Add(mpv-release
         -Dvulkan=enabled
         -Dvapoursynth=enabled
         -Dsubrandr=enabled
-        -Dsixel=enabled
+        -Dsixel=disabled
         ${mpv_gl}
         -Dc_args='-Wno-error=int-conversion'
     BUILD_COMMAND ${EXEC} LTO_JOB=1 ninja -C <BINARY_DIR>
diff --git a/packages/mpv.cmake b/packages/mpv.cmake
index 8624aec..6a3e8c6 100644
--- a/packages/mpv.cmake
+++ b/packages/mpv.cmake
@@ -23,7 +23,7 @@ ExternalProject_Add(mpv
         vapoursynth
         libsdl2
         subrandr
-        libsixel
+        # libsixel
-    GIT_REPOSITORY https://github.com/mpv-player/mpv.git
+    GIT_REPOSITORY https://github.com/178meorg/mpv.git
     SOURCE_DIR ${SOURCE_LOCATION}
     GIT_CLONE_FLAGS "--filter=tree:0"
@@ -55,7 +55,7 @@ ExternalProject_Add(mpv
         -Dvulkan=enabled
         -Dvapoursynth=enabled
         -Dsubrandr=enabled
-        -Dsixel=enabled
+        -Dsixel=disabled
         ${mpv_gl}
         -Dc_args='-Wno-error=int-conversion'
     BUILD_COMMAND ${EXEC} LTO_JOB=1 PDB=1 ninja -C <BINARY_DIR>
-- 
2.52.0
